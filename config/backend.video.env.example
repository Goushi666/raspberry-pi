# 复制到业务后端仓库的 backend/.env（或部署环境变量）
# 与《硬件端-Software通讯与对接说明》§5、§5.5 一致：浏览器经该 URL 拉 MJPEG，不经过 FastAPI 传视频字节。
#
# 将 <车机IP> 换为树莓派在局域网中的地址；端口、路径须与车端 config.yaml → video_stream 一致。

VIDEO_MJPEG_URL=http://<车机IP>:8080/mjpeg

# 若使用 HLS（如 scripts/hls_from_camera.sh + http.server），则配置播放列表地址，与 MJPEG 二选一或按前端逻辑：
# VIDEO_HLS_PLAYLIST_URL=http://<车机IP>:8888/index.m3u8
